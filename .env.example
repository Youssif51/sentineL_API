# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/seer_price

# ── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_strong_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Paymob ────────────────────────────────────────
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# ── Email (SMTP) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@seerprice.com

# ── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=

# ── Rate Limiting ─────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
